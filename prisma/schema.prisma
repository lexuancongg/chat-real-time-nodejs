generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          BigInt  @id @default(autoincrement())
  username    String  @unique
  password    String
  displayName String?
  phone       String? @unique
  avatarId    BigInt? @unique
  status      Status  @default(OFFLINE)

  createdAt DateTime @default(now())

  avatar               Image?              @relation("UserAvatar", fields: [avatarId], references: [id])
  conversationMembers  ConversationMember[]
  devices              Device[]
  friends              Friend[]            @relation("UserFriends")
  friendOf             Friend[]            @relation("UserFriends_Friend")
  friendRequestsSent   FriendRequest[]     @relation("RequestsSent")
  friendRequestsReceived FriendRequest[]   @relation("RequestsReceived")
  blocksInitiated      Block[]             @relation("BlocksInitiated")
  blockedBy            Block[]             @relation("BlockedBy")
  messages             Message[]
}



model Image {
  id        BigInt   @id @default(autoincrement())
  url       String
  publicId  String?
  createdAt DateTime @default(now())

  user User? @relation("UserAvatar")
}



model FriendRequest {
  id         BigInt              @id @default(autoincrement())
  senderId   BigInt
  receiverId BigInt
  status     FriendRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("RequestsSent",     fields: [senderId],   references: [id])
  receiver User @relation("RequestsReceived", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId])   
}


model Friend {
  id       BigInt @id @default(autoincrement())
  userId   BigInt
  friendId BigInt

  createdAt DateTime @default(now())

  user   User @relation("UserFriends",        fields: [userId],   references: [id])
  friend User @relation("UserFriends_Friend", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}


model Block {
  id        BigInt   @id @default(autoincrement())
  blockerId BigInt
  blockedId BigInt
  createdAt DateTime @default(now())

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id])
  blocked User @relation("BlockedBy",       fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}



model Conversation {
  id            BigInt   @id @default(autoincrement())
  isGroup       Boolean  @default(false)
  name          String?  // tên nhóm (nếu isGroup = true)
  lastMessageId BigInt?
  createdAt     DateTime @default(now())

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  id             BigInt    @id @default(autoincrement())
  conversationId BigInt
  userId         BigInt
  role           GroupRole @default(MEMBER)
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId],         references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}



model Message {
  id             BigInt        @id @default(autoincrement())
  conversationId BigInt
  senderId       BigInt
  content        String
  type           MessageType   @default(TEXT)
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId],       references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}



model Device {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt
  deviceId   String
  deviceName String?
  pushToken  String?
  lastSeen   DateTime?
  isOnline   Boolean   @default(false)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId])
}


enum Status {
  ONLINE
  OFFLINE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GroupRole {
  MEMBER
  ADMIN
  OWNER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  SEEN
}
